<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List (Tree) View -->
    <record id="vendor_evaluation_report_tree_view" model="ir.ui.view">
        <field name="name">vendor.evaluation.report.list</field>
        <field name="model">vendor.evaluation.report</field>
        <field name="arch" type="xml">
            <list string="Vendor Evaluation Report" create="false" edit="false" delete="false">
                <field name="product_id"/>
                <field name="product_brand_id"/>
                <field name="vendor_id"/>
                <field name="total_purchase_cost" sum="Total Purchase Cost"/>
                <field name="total_sales" sum="Total Sales"/>
                <field name="stock_amount"/>
                <field name="uom_id"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="vendor_evaluation_report_search_view" model="ir.ui.view">
        <field name="name">vendor.evaluation.report.search</field>
        <field name="model">vendor.evaluation.report</field>
        <field name="arch" type="xml">
            <search string="Vendor Evaluation Report Search">
                <field name="product_id"/>
                <field name="vendor_id"/>
                <field name="product_brand_id"/>
                <group expand="0" string="Group By">
                    <filter string="Vendor" name="group_by_vendor" context="{'group_by':'vendor_id'}"/>
                    <filter string="Brand" name="group_by_brand" context="{'group_by':'product_brand_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Server Action -->
    <record id="action_vendor_evaluation_report" model="ir.actions.server">
        <field name="name">Vendor Evaluation Report</field>
        <field name="model_id" ref="edit_account.model_vendor_evaluation_report"/>
        <field name="state">code</field>
        <field name="code">
            action = env['vendor.evaluation.report'].action_generate_report()
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_vendor_evaluation_report"
              name="Vendor Evaluation Report"
              parent="account.menu_finance_reports"
              action="action_vendor_evaluation_report"
              sequence="100"/>
</odoo>
