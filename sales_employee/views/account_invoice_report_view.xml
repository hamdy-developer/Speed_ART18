<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_invoice_report_search_sales_employee" model="ir.ui.view">
        <field name="name">account.invoice.report.search.sales_employee</field>
        <field name="model">account.invoice.report</field>
        <field name="inherit_id" ref="account.view_account_invoice_report_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="sales_employee_id" operator="child_of"/>
            </xpath>
            <xpath expr="//filter[@name='user']" position="after">
                <filter string="Sales Employee" name="sales_employee" context="{'group_by':'sales_employee_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_invoice_report_list_sales_employee" model="ir.ui.view">
        <field name="name">account.invoice.report.list.sales_employee</field>
        <field name="model">account.invoice.report</field>
        <field name="inherit_id" ref="account.account_invoice_report_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="sales_employee_id" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
