<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_order_product_search_sales_employee" model="ir.ui.view">
        <field name="name">sale.report.search.sales_employee</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="sales_employee_id"/>
                <field name="invoice_date"/>
            </xpath>
            <xpath expr="//filter[@name='User']" position="after">
                <filter string="Sales Employee" name="sales_employee" context="{'group_by':'sales_employee_id'}"/>
                <filter string="Invoice Date" name="invoice_date" context="{'group_by':'invoice_date'}"/>
            </xpath>
        </field>
    </record>

    <!-- List View -->
    <record id="sale_report_view_tree_sales_employee" model="ir.ui.view">
        <field name="name">sale.report.view.list.sales_employee</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.sale_report_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="sales_employee_id" optional="show"/>
                <field name="invoice_date" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='price_total']" position="after">
                <field name="amount_paid" optional="show" sum="Sum of Amount Paid"/>
            </xpath>
        </field>
    </record>
</odoo>
